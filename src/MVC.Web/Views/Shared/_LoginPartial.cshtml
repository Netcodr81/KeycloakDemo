<div class="nav-item px-3">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="flex flex-col items-end gap-2">
            <span>Welcome @User.Claims.FirstOrDefault(c => c.Type == "name")?.Value</span>
            <a class="text-blue-600 hover:underline" asp-action="SignOut" asp-controller="Authorization">
               Logout
            </a>

        </div>
    }
    else
    {
        <a class="text-blue-600 hover:underline" asp-action="SignIn" asp-controller="Authorization">
           Login
        </a>
    }
</div>
