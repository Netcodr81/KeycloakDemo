@using MVC.Framework.Web.Models
@{
    ViewData["Title"] = "User Information";
    var accessTokenPanelModel = ViewData["AccessTokenModel"] as AccessTokenViewModel;
    var refreshTokenModel = ViewData["RefreshTokenModel"] as RefreshTokenViewModel;
    var claimsPanelModel = ViewData["ClaimsPanelModel"] as ClaimsPanelViewModel;
}

@*Refresh Token Panel*@

<h3 class="text-2xl mb-4">User Information</h3>
<div class="flex flex-col gap-6">
    <div d="refreshTokenPanelContainer" class="border-b border-gray-200 bg-white tablet:px-4 py-5 px-6">
        <div class="mt-4 ml-4 flex flex-wrap items-center justify-between sm:flex-nowrap">
            <div class="mt-4 ml-4">
                <h3 class="text-base font-semibold text-gray-900">Refresh Token</h3>
            </div>
            <div i class="mt-4 ml-4 shrink-0 gap-2 flex">
                @using (Html.BeginForm("RefreshToken", "User", FormMethod.Post, new {id= "refreshTokenForm"})) {

                <button type="submit"
                        class="relative inline-flex items-center rounded-md bg-zinc-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2">
                    Refresh Token Manually
                </button>

                }
            </div>
        </div>
        <div class="border-zinc-800 border p-8 mt-4">
            <div class="grid grid-cols-[auto,1fr] items-center gap-x-6 gap-y-4 text-sm">
                <div class="font-medium text-gray-600">Token Expiration</div>
                <div
                    class="font-mono text-gray-900 bg-gray-100 p-2 rounded-md">@(refreshTokenModel?.TokenExpiration?.LocalDateTime.ToString("F") ?? "N/A")</div>

                <div class="font-medium text-gray-600">Token Issued At</div>
                <div
                    class="font-mono text-gray-900 bg-gray-100 p-2 rounded-md">@(refreshTokenModel?.TokenIssuedAt?.LocalDateTime.ToString("F") ?? "N/A")</div>

                <div class="font-medium text-gray-600">Last Authenticated At</div>
                <div
                    class="font-mono text-gray-900 bg-gray-100 p-2 rounded-md">@(refreshTokenModel?.LastAuthenticatedAt?.LocalDateTime.ToString("F") ?? "N/A")</div>
            </div>
        </div>
    </div>

    @*Claims Panel*@

    <div class="border-b border-gray-200 bg-white tablet:px-4 py-5 px-6">
        <div class="mt-4 ml-4 flex flex-wrap items-center justify-between sm:flex-nowrap">
            <div class="mt-4 ml-4">
                <h3 class="text-base font-semibold text-gray-900">User Claims</h3>
            </div>
            <div class="mt-4 ml-4 shrink-0 gap-2 flex">
            @using (Html.BeginForm("ShowClaims", "User", FormMethod.Post, new {id= "showClaimsForm"}))
            {
                    <button type="submit"
                            class="relative inline-flex items-center rounded-md bg-zinc-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2">
                        Show Claims
                    </button>
            }
            @using (Html.BeginForm("ClearClaims", "User", FormMethod.Post, new {id= "clearClaimsForm"})){
                <button type="submit"
                        class="relative inline-flex items-center rounded-md bg-zinc-300 px-3 py-2 text-sm font-semibold text-zinc-800 shadow-xs hover:bg-zinc-200 focus-visible:outline-2 focus-visible:outline-offset-2">
                    Clear Claims
                </button>
            }
            </div>
        </div>
        <div id="claimsContainer" class="min-h-[600px] max-h-[600px] border-zinc-800 border p-8 mt-4 overflow-y-auto">
             @if (claimsPanelModel.Claims.Any())
                {
                <ul>
                    @foreach (var claim in claimsPanelModel.Claims)
                    {
                    <li><b>@claim.Type:</b> @claim.Value</li>
                    }
                </ul>
            }
        </div>
    </div>

    @*Access Token Panel*@
    <div class="border-b border-gray-200 bg-white tablet:px-4 py-5 px-6">
        <div class="mt-4 ml-4 flex flex-wrap items-center justify-between sm:flex-nowrap">
            <div class="mt-4 ml-4">
                <h3 class="text-base font-semibold text-gray-900">Access Token</h3>
            </div>
            <div class="mt-4 ml-4 shrink-0 gap-2 flex">
            @using (Html.BeginForm("ShowAccessToken", "User", FormMethod.Post, new {id = "showTokenForm"}))
            {
                    <button type="submit"
                            class="relative inline-flex items-center rounded-md bg-zinc-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2">
                        Show Access Token
                    </button>
            }
            @using (Html.BeginForm("DecodeAccessToken", "User", FormMethod.Post, new {id = "decodeTokenForm"}))
            {
                    <input type="hidden" id="accessTokenInput" name="accessToken"
                           value="@accessTokenPanelModel.AccessToken"/>
                    <button id="decodeTokenButton" type="submit"
                            class="relative inline-flex items-center rounded-md bg-zinc-300 px-3 py-2 text-sm font-semibold text-zinc-800 shadow-xs hover:bg-zinc-200 focus-visible:outline-2 focus-visible:outline-offset-2 @(string.IsNullOrEmpty(accessTokenPanelModel.AccessToken) ? "opacity-50" : "")"
                            @(string.IsNullOrEmpty(accessTokenPanelModel.AccessToken) ? "disabled" : "")>
                        Decode Access Token
                    </button>
            }
            @using (Html.BeginForm("ClearAccessToken", "User", FormMethod.Post, new {id = "clearTokenForm"}))
            {
                    <button type="submit"
                            class="relative inline-flex items-center rounded-md bg-red-500 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-red-400 focus-visible:outline-2 focus-visible:outline-offset-2">
                        Clear Access Token
                    </button>
            }
            <button id="copyTokenButton" type="button"
                        class="relative inline-flex text-white items-center rounded-md bg-blue-800 px-3 py-2 text-sm font-semibold shadow-xs hover:bg-blue-600 focus-visible:outline-2 focus-visible:outline-offset-2 @(string.IsNullOrEmpty(accessTokenPanelModel.AccessToken) ? "opacity-50" : "")"
                        @(string.IsNullOrEmpty(accessTokenPanelModel.AccessToken) ? "disabled" : "")>
                    Copy Access Token
                </button>
            </div>
        </div>
        <div id="tokenContainer"
             class="min-h-[600px] max-h-[600px] border-zinc-800 border p-8 mt-4 break-all overflow-y-auto">
            @if (!string.IsNullOrEmpty(accessTokenPanelModel.AccessToken) && string.IsNullOrEmpty(accessTokenPanelModel.DecodedToken))
            {
                <p>@accessTokenPanelModel.AccessToken</p>
            }
            @if (!string.IsNullOrEmpty(accessTokenPanelModel.AccessToken) && !string.IsNullOrEmpty(accessTokenPanelModel.DecodedToken))
            {
                <pre>@accessTokenPanelModel.DecodedToken</pre>
            }
        </div>
    </div>

</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mt-4" role="alert">
        <p>@TempData["SuccessMessage"]</p>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mt-4" role="alert">
        <p>@TempData["ErrorMessage"]</p>
    </div>
}


<script>
    document.addEventListener('DOMContentLoaded', function () {
        const showTokenForm = document.getElementById('showTokenForm');
        const decodeTokenForm = document.getElementById('decodeTokenForm');
        const clearTokenForm = document.getElementById('clearTokenForm');
        const copyTokenButton = document.getElementById('copyTokenButton');
        const decodeTokenButton = document.getElementById('decodeTokenButton');
        const tokenContainer = document.getElementById('tokenContainer');
        const accessTokenInput = document.getElementById('accessTokenInput');
        const refreshTokenForm = document.getElementById('refreshTokenForm');
        const showClaimsForm = document.getElementById('showClaimsForm');
        const clearClaimsForm = document.getElementById('clearClaimsForm');
        const claimsContainer = document.getElementById('claimsContainer');

        function setButtonsState(enabled) {
            if (enabled) {
                decodeTokenButton.classList.remove('opacity-50');
                decodeTokenButton.disabled = false;
                copyTokenButton.classList.remove('opacity-50');
                copyTokenButton.disabled = false;
            } else {
                decodeTokenButton.classList.add('opacity-50');
                decodeTokenButton.disabled = true;
                copyTokenButton.classList.add('opacity-50');
                copyTokenButton.disabled = true;
            }
        }

        showClaimsForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            fetch(this.action, { method: 'POST', body: formData })
                .then(res => res.text())
                .then(data => {
                    claimsContainer.innerHTML = data;
                })
                .catch(err => console.error('Error decoding token:', err));
        });

        clearClaimsForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            fetch(this.action, {method: 'POST', body: formData})
                .then(res => res.text())
                .then(data => {
                    claimsContainer.innerHTML = data;
                })
                .catch(err => console.error('Error decoding token:', err));
        });

        refreshTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            fetch(this.action, {method: 'POST', body: formData})
                .then(res => res.json())
                .then(data => {
                    tokenContainer.innerHTML = data;
                })
                .catch(err => console.error('Error decoding token:', err));
        });

        showTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            fetch(this.action, {method: 'POST'})
                .then(res => res.json())
                .then(data => {
                    tokenContainer.innerHTML = `<p>${data.accessToken}</p>`;
                    accessTokenInput.value = data.accessToken;
                    setButtonsState(true);
                })
                .catch(err => console.error('Error showing token:', err));
        });

        decodeTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            fetch(this.action, {method: 'POST', body: formData})
                .then(res => res.json())
                .then(data => {
                    tokenContainer.innerHTML = `<pre>${data.decodedToken}</pre>`;
                })
                .catch(err => console.error('Error decoding token:', err));
        });

        clearTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            fetch(this.action, {method: 'POST'})
                .then(() => {
                    tokenContainer.innerHTML = '';
                    accessTokenInput.value = '';
                    setButtonsState(false);
                })
                .catch(err => console.error('Error clearing token:', err));
        });

        copyTokenButton.addEventListener('click', function () {
            const content = tokenContainer.innerText;
            if (content) {
                navigator.clipboard.writeText(content)
                    .then(() => alert('Content copied to clipboard.'))
                    .catch(err => console.error('Failed to copy:', err));
            }
        });
    });
</script>