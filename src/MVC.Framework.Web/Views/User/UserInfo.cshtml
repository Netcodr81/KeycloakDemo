@using MVC.Framework.Web.Models
@{
    ViewData["Title"] = "User Information";
    var accessTokenPanelModel = ViewData["AccessTokenModel"] as AccessTokenViewModel;
    var refreshTokenModel = ViewData["RefreshTokenModel"] as RefreshTokenViewModel;
    var claimsPanelModel = ViewData["ClaimsPanelModel"] as ClaimsPanelViewModel;
}

<h3 class="text-2xl mb-4">User Information</h3>
<div class="flex flex-col gap-6">
    @{ Html.RenderPartial("./Partials/_RefreshTokenPanel", refreshTokenModel); }
    @{
        Html.RenderPartial("./Partials/_ClaimsPanel", claimsPanelModel);
    }
    @{ Html.RenderPartial("./Partials/_AccessTokenPanel", accessTokenPanelModel); }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mt-4" role="alert">
        <p>@TempData["SuccessMessage"]</p>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mt-4" role="alert">
        <p>@TempData["ErrorMessage"]</p>
    </div>
}
