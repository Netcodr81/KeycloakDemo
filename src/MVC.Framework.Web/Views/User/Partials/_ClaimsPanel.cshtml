@model MVC.Framework.Web.Models.ClaimsPanelViewModel

<div class="border-b border-gray-200 bg-white tablet:px-4 py-5 px-6">
    <div class="mt-4 ml-4 flex flex-wrap items-center justify-between sm:flex-nowrap">
        <div class="mt-4 ml-4">
            <h3 class="text-base font-semibold text-gray-900">User Claims</h3>
        </div>
        <div class="mt-4 ml-4 shrink-0 gap-2 flex">
            <form id="showClaimsForm" method="post" asp-action="ShowClaims" asp-controller="User">
                <button type="submit" class="relative inline-flex items-center rounded-md bg-zinc-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2">Show Claims</button>
            </form>

            <form id="clearClaimsForm" method="post" asp-action="ClearClaims" asp-controller="User">
                <button type="submit" class="relative inline-flex items-center rounded-md bg-zinc-300 px-3 py-2 text-sm font-semibold text-zinc-800 shadow-xs hover:bg-zinc-200 focus-visible:outline-2 focus-visible:outline-offset-2">Clear Claims</button>
            </form>
        </div>
    </div>
    <div id="claimsContainer" class="min-h-[600px] max-h-[600px] border-zinc-800 border p-8 mt-4 overflow-y-auto">
        @if (Model.Claims.Any())
        {
            <ul>
                @foreach (var claim in Model.Claims)
                {
                    <li><b>@claim.Type:</b> @claim.Value</li>
                }
            </ul>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const showClaimsForm = document.getElementById('showClaimsForm');
        const clearClaimsForm = document.getElementById('clearClaimsForm');
        const claimsContainer = document.getElementById('claimsContainer');

        showClaimsForm.addEventListener('submit', function (event) {
            event.preventDefault();

            // Use the Fetch API to post to the controller action.
            fetch(this.action, {
                method: 'POST',
                headers: {
                    // Add antiforgery token header if you have it configured.
                    // 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json(); // Expecting JSON from the controller.
                })
                .then(claims => {
                    // Clear previous claims and build the new list.
                    claimsContainer.innerHTML = '';
                    if (claims && claims.length > 0) {
                        const ul = document.createElement('ul');
                        claims.forEach(claim => {
                            const li = document.createElement('li');
                            li.innerHTML = `<b>${escapeHtml(claim.type)}:</b> ${escapeHtml(claim.value)}`;
                            ul.appendChild(li);
                        });
                        claimsContainer.appendChild(ul);
                    }
                })
                .catch(error => {
                    console.error('Error fetching claims:', error);
                    claimsContainer.innerHTML = '<p class="text-red-500">Failed to load claims.</p>';
                });
        });

        clearClaimsForm.addEventListener('submit', function(event) {
            event.preventDefault();
            fetch(this.action, { method: 'POST' })
                .then(() => {
                    claimsContainer.innerHTML = '';
                })
                .catch(error => console.error('Error clearing claims:', error));
        });

        function escapeHtml(unsafe) {
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    });
</script>
