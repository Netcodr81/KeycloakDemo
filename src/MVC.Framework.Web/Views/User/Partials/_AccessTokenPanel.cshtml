@model MVC.Framework.Web.Models.AccessTokenViewModel

<div class="border-b border-gray-200 bg-white tablet:px-4 py-5 px-6">
    <div class="mt-4 ml-4 flex flex-wrap items-center justify-between sm:flex-nowrap">
        <div class="mt-4 ml-4">
            <h3 class="text-base font-semibold text-gray-900">Access Token</h3>
        </div>
        <div class="mt-4 ml-4 shrink-0 gap-2 flex">
            <form id="showTokenForm" method="post" asp-action="ShowAccessToken" asp-controller="User">
                <button type="submit" class="relative inline-flex items-center rounded-md bg-zinc-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-zinc-500 focus-visible:outline-2 focus-visible:outline-offset-2">
                    Show Access Token
                </button>
            </form>

            <form id="decodeTokenForm" method="post" asp-action="DecodeAccessToken" asp-controller="User">
                <input type="hidden" id="accessTokenInput" name="accessToken" value="@Model.AccessToken" />
                <button id="decodeTokenButton" type="submit" class="relative inline-flex items-center rounded-md bg-zinc-300 px-3 py-2 text-sm font-semibold text-zinc-800 shadow-xs hover:bg-zinc-200 focus-visible:outline-2 focus-visible:outline-offset-2 @(string.IsNullOrEmpty(Model.AccessToken) ? "opacity-50" : "")" @(string.IsNullOrEmpty(Model.AccessToken) ? "disabled" : "")>
                    Decode Access Token
                </button>
            </form>

            <form id="clearTokenForm" method="post" asp-action="ClearAccessToken" asp-controller="User">
                <button type="submit" class="relative inline-flex items-center rounded-md bg-red-500 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-red-400 focus-visible:outline-2 focus-visible:outline-offset-2">
                    Clear Access Token
                </button>
            </form>

            <button id="copyTokenButton" type="button" class="relative inline-flex text-white items-center rounded-md bg-blue-800 px-3 py-2 text-sm font-semibold shadow-xs hover:bg-blue-600 focus-visible:outline-2 focus-visible:outline-offset-2 @(string.IsNullOrEmpty(Model.AccessToken) ? "opacity-50" : "")" @(string.IsNullOrEmpty(Model.AccessToken) ? "disabled" : "")>
                Copy Access Token
            </button>
        </div>
    </div>
    <div id="tokenContainer" class="min-h-[600px] max-h-[600px] border-zinc-800 border p-8 mt-4 break-all overflow-y-auto">
        @if (!string.IsNullOrEmpty(Model.AccessToken) && string.IsNullOrEmpty(Model.DecodedToken))
        {
            <p>@Model.AccessToken</p>
        }
        @if (!string.IsNullOrEmpty(Model.AccessToken) && !string.IsNullOrEmpty(Model.DecodedToken))
        {
            <pre>@Model.DecodedToken</pre>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const showTokenForm = document.getElementById('showTokenForm');
        const decodeTokenForm = document.getElementById('decodeTokenForm');
        const clearTokenForm = document.getElementById('clearTokenForm');
        const copyTokenButton = document.getElementById('copyTokenButton');
        const decodeTokenButton = document.getElementById('decodeTokenButton');
        const tokenContainer = document.getElementById('tokenContainer');
        const accessTokenInput = document.getElementById('accessTokenInput');

        function setButtonsState(enabled) {
            if (enabled) {
                decodeTokenButton.classList.remove('opacity-50');
                decodeTokenButton.disabled = false;
                copyTokenButton.classList.remove('opacity-50');
                copyTokenButton.disabled = false;
            } else {
                decodeTokenButton.classList.add('opacity-50');
                decodeTokenButton.disabled = true;
                copyTokenButton.classList.add('opacity-50');
                copyTokenButton.disabled = true;
            }
        }

        showTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            fetch(this.action, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    tokenContainer.innerHTML = `<p>${data.accessToken}</p>`;
                    accessTokenInput.value = data.accessToken;
                    setButtonsState(true);
                })
                .catch(err => console.error('Error showing token:', err));
        });

        decodeTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            fetch(this.action, { method: 'POST', body: formData })
                .then(res => res.json())
                .then(data => {
                    tokenContainer.innerHTML = `<pre>${data.decodedToken}</pre>`;
                })
                .catch(err => console.error('Error decoding token:', err));
        });

        clearTokenForm.addEventListener('submit', function (e) {
            e.preventDefault();
            fetch(this.action, { method: 'POST' })
                .then(() => {
                    tokenContainer.innerHTML = '';
                    accessTokenInput.value = '';
                    setButtonsState(false);
                })
                .catch(err => console.error('Error clearing token:', err));
        });

        copyTokenButton.addEventListener('click', function() {
            const content = tokenContainer.innerText;
            if (content) {
                navigator.clipboard.writeText(content)
                    .then(() => alert('Content copied to clipboard.'))
                    .catch(err => console.error('Failed to copy:', err));
            }
        });
    });
</script>